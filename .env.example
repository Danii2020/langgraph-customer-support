# OpenAI API key
OPENAI_API_KEY=YOUR-KEY
AWS_ACCESS_KEY_ID=YOUR-KEY
AWS_SECRET_ACCESS_KEY=YOUR-KEY

# --- LangSmith observability ---
# Master switch: set to "true" to enable trace export to LangSmith.
LANGSMITH_TRACING=true
# API key from https://smith.langchain.com/settings — keep this secret.
LANGSMITH_API_KEY=YOUR-KEY
# Project name shown in the LangSmith UI; each unique value creates a separate project bucket.
LANGSMITH_PROJECT=langgraph-gmail
# LangSmith API endpoint; leave as-is unless you use a self-hosted or EU instance.
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
