# OpenAI API key
OPENAI_API_KEY=YOUR-KEY
AWS_ACCESS_KEY_ID=YOUR-KEY
AWS_SECRET_ACCESS_KEY=YOUR-KEY
LANGSMITH_API_KEY=YOUR-KEY

# LLM Model IDs (Amazon Bedrock)
LLM_WRITER=YOUR-BEDROCK-MODEL-ID
LLM_CATEGORIZER=YOUR-BEDROCK-MODEL-ID

# Amazon Knowledge Bases ID for RAG retrieval.
# Value comes from the kb_provisioning SAM stack output "KnowledgeBaseId".
# After running: cd kb_provisioning && sam deploy --config-file samconfig.toml
# retrieve with: aws cloudformation describe-stacks --stack-name kb-provisioning \
#   --region us-east-1 --query "Stacks[0].Outputs[?OutputKey=='KnowledgeBaseId'].OutputValue" --output text
KNOWLEDGE_BASE_ID=YOUR-KNOWLEDGE-BASE-ID


# AWS region used for X-Ray trace context propagation
AWS_REGION=us-east-2
